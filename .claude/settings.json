{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/enforce-concise-response.sh",
            "type": "command"
          }
        ],
        "matcher": "Task"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/memory-capture.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "node .claude/hooks/memory-capture.cjs",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "node .claude/hooks/nudge-claude-md-update.cjs",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/block-orchestrator-tools.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/enforce-bead-for-supervisor.sh",
            "type": "command"
          },
          {
            "command": ".claude/hooks/enforce-sequential-dispatch.sh",
            "type": "command"
          },
          {
            "command": ".claude/hooks/remind-inprogress.sh",
            "type": "command"
          },
          {
            "command": ".claude/hooks/inject-discipline-reminder.sh",
            "type": "command"
          },
          {
            "command": ".claude/hooks/inject-memory-recall.sh",
            "type": "command"
          }
        ],
        "matcher": "Task"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/validate-epic-close.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/enforce-branch-before-edit.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/enforce-branch-before-edit.sh",
            "type": "command"
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "command": "node .claude/hooks/enforce-branch-before-edit.cjs",
            "type": "command"
          }
        ],
        "matcher": "Edit"
      },
      {
        "hooks": [
          {
            "command": "node .claude/hooks/enforce-branch-before-edit.cjs",
            "type": "command"
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "command": "node .claude/hooks/bash-guard.cjs",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/session-start.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "node .claude/hooks/session-start.cjs",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/validate-completion.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "node .claude/hooks/validate-completion.cjs",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/clarify-vague-request.sh",
            "type": "command"
          }
        ]
      }
    ]
  }
}